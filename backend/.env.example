# Backend
BACKEND_PORT=8000
LOG_DIR=logs

# ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MAIN_MODEL=qwen3:14b
LLM_FAST_MODEL=qwen3:4b
LLM_NSFW_MODEL=huihui_ai/qwen3-abliterated:14b
LLM_VL_MODEL=huihui_ai/qwen3-vl-abliterated:8b
LLM_EMBED_MODEL=nomic-embed-text
LLM_CODER_MODEL=qwen2.5-coder:14b

# ComfyUI
COMFYUI_BASE_URL=http://localhost:8188

# TIPO (2026-06-18 실측: 500M-ft + GPU 확정)
TIPO_MODEL_SIZE=500m
TIPO_MODEL=KBlueLeaf/TIPO-500M-ft
TIPO_DEVICE=cuda

# Cloud LLM (optional, SFW-only tasks)
CLOUD_LLM_API_KEY=
CLOUD_LLM_MODEL=claude-sonnet-4-6

# mem0 / Qdrant
QDRANT_URL=http://localhost:6333
