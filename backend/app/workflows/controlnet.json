{
  "_comment": "ComfyUI ControlNet openpose (pose transplant, Doc 14 mode=pose). Reference(10) -> OpenposePreprocessor(14) -> pose skeleton. Union promax(15) + SetUnionControlNetType(16,openpose). ControlNetApplyAdvanced(17) conditions pos/neg from the pose map; KSampler uses 17's conditioning. Character comes from the text prompt.",
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["4", 0],
      "positive": ["17", 0],
      "negative": ["17", 1],
      "latent_image": ["5", 0],
      "seed": "__SEED__",
      "steps": "__STEPS__",
      "cfg": "__CFG__",
      "sampler_name": "__SAMPLER__",
      "scheduler": "__SCHEDULER__",
      "denoise": "__DENOISE__"
    }
  },
  "4": { "class_type": "CheckpointLoaderSimple", "inputs": { "ckpt_name": "__CHECKPOINT__" } },
  "5": { "class_type": "EmptyLatentImage", "inputs": { "width": "__WIDTH__", "height": "__HEIGHT__", "batch_size": 1 } },
  "6": { "class_type": "CLIPTextEncode", "inputs": { "clip": ["4", 1], "text": "__POSITIVE__" } },
  "7": { "class_type": "CLIPTextEncode", "inputs": { "clip": ["4", 1], "text": "__NEGATIVE__" } },
  "8": { "class_type": "VAEDecode", "inputs": { "samples": ["3", 0], "vae": ["4", 2] } },
  "9": { "class_type": "SaveImage", "inputs": { "images": ["8", 0], "filename_prefix": "output" } },
  "10": { "class_type": "LoadImage", "inputs": { "image": "__REFERENCE__" } },
  "14": {
    "class_type": "OpenposePreprocessor",
    "inputs": { "image": ["10", 0], "detect_hand": "enable", "detect_body": "enable", "detect_face": "enable", "scale_stick_for_xinsr_cn": "disable", "resolution": 512 }
  },
  "15": { "class_type": "ControlNetLoader", "inputs": { "control_net_name": "controlnet-union-sdxl-promax.safetensors" } },
  "16": { "class_type": "SetUnionControlNetType", "inputs": { "control_net": ["15", 0], "type": "openpose" } },
  "17": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["6", 0],
      "negative": ["7", 0],
      "control_net": ["16", 0],
      "image": ["14", 0],
      "strength": 1.0,
      "start_percent": 0.0,
      "end_percent": 1.0
    }
  }
}
